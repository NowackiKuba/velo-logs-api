# Local overrides — copy from .env.example
DATABASE_URL=postgres://postgres:secret_password@localhost:5432/velo_logs_db
REDIS_HOST=localhost
REDIS_PORT=6379
JWT_SECRET=dev-local-jwt-secret-min-32-chars-long
RUN_BENCHMARK=true
ENDPOINT_CACHE_TTL_SECONDS=60
WORKER_CONCURRENCY=10
ENABLE_EMBEDDED_WORKER=false 